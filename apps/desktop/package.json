{
  "name": "desktop",
  "private": true,
  "version": "0.1.4",
  "description": "SnapKO Desktop Application",
  "author": "SnapKO Team",
  "packageManager": "pnpm@9.12.3",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "rebuild-sqlite": "npx rimraf ../../node_modules/better-sqlite3/build && npx @electron/rebuild -f -w better-sqlite3",
    "postinstall": "pnpm rebuild-sqlite",
    "build:win": "pnpm build && electron-builder --win --config --publish never",
    "dist": "pnpm build && electron-builder"
  },
  "build": {
    "appId": "com.snapko.desktop",
    "productName": "SnapKO Desktop",
    "electronVersion": "34.0.0",
    "directories": {
      "output": "dist-exes"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "../../node_modules/better-sqlite3/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SnapKO"
    },
    "extraResources": [
      ".env"
    ]
  },
  "dependencies": {
    "@snapko/shared": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3",
    "electron-store": "8",
    "lucide-react": "^0.562.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "34.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vite": "^6.4.1"
  }
}
