/**
 * Environment Configuration Example
 * Per .antigravityrules: NEVER commit .env, ALWAYS commit .env.example
 * 
 * Copy this file to .env and fill in your values
 */

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth Configuration
# Get these from Google Cloud Console > APIs & Services > Credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com

# ==============================================================
# SETUP INSTRUCTIONS:
# ==============================================================
#
# 1. GOOGLE CLOUD CONSOLE:
#    - Go to https://console.cloud.google.com/
#    - Create OAuth 2.0 Client IDs for Web, iOS, Android
#    - For Web: Add authorized redirect URI:
#      https://your-project.supabase.co/auth/v1/callback
#    - For iOS: Add bundle ID: com.snapko.app
#    - For Android: Add package name: com.snapko.app
#
# 2. SUPABASE DASHBOARD:
#    - Go to Authentication > URL Configuration
#    - Add Redirect URLs:
#      - exp://localhost:8081/--/auth/callback (Expo Go dev)
#      - snapko://auth/callback (Production builds)
#
# 3. ENABLE GOOGLE PROVIDER:
#    - Go to Authentication > Providers > Google
#    - Enable and add your Web Client ID and Secret
#
# ==============================================================
