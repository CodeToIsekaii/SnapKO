{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "paths": {
      "@snapko/shared": ["../../packages/shared/src"],
      "@snapko/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "app/**/*"],
  "exclude": ["node_modules"]
}
