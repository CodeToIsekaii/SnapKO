{
  "expo": {
    "name": "SnapKO",
    "slug": "snapko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "snapko",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snapko.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SnapKO cần truy cập Camera để chụp hóa đơn nhập kho.",
        "NSPhotoLibraryUsageDescription": "SnapKO cần truy cập thư viện ảnh để chọn hóa đơn có sẵn.",
        "NSPhotoLibraryAddUsageDescription": "SnapKO cần quyền lưu ảnh để sao lưu hóa đơn.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.snapko.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "snapko"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SnapKO cần truy cập Camera để chụp hóa đơn nhập kho."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SnapKO cần truy cập thư viện ảnh để chọn hóa đơn có sẵn."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "d49fb5d3-0e2a-40c1-8f77-3fef51fdb1ca"
      }
    },
    "owner": "lazzymoney"
  }
}
